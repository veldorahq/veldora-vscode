{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Veldora Templates",
    "scopeName": "text.html.veldora",
    "patterns": [
        { "include": "#php-block" },
        { "include": "#php-short-echo" },
        { "include": "#veldora-comment" },
        { "include": "#veldora-raw-echo" },
        { "include": "#veldora-echo" },
        { "include": "#veldora-directives" },
        { "include": "#veldora-components" },
        { "include": "text.html.basic" }
    ],
    "repository": {

        "php-block": {
            "patterns": [
                {
                    "name": "meta.embedded.block.php",
                    "begin": "<\\?(?:php|=)?",
                    "beginCaptures": {
                        "0": { "name": "punctuation.section.embedded.begin.php" }
                    },
                    "end": "\\?>",
                    "endCaptures": {
                        "0": { "name": "punctuation.section.embedded.end.php" }
                    },
                    "patterns": [
                        { "include": "source.php" }
                    ]
                }
            ]
        },

        "php-short-echo": {
            "patterns": [
                {
                    "name": "meta.embedded.line.php",
                    "begin": "<\\?=",
                    "beginCaptures": {
                        "0": { "name": "punctuation.section.embedded.begin.php" }
                    },
                    "end": "\\?>",
                    "endCaptures": {
                        "0": { "name": "punctuation.section.embedded.end.php" }
                    },
                    "patterns": [
                        { "include": "source.php" }
                    ]
                }
            ]
        },

        "veldora-comment": {
            "patterns": [
                {
                    "name": "comment.block.veldora",
                    "begin": "\\{\\{--",
                    "end": "--\\}\\}"
                }
            ]
        },

        "veldora-raw-echo": {
            "patterns": [
                {
                    "name": "meta.expression.raw.veldora",
                    "begin": "\\{!!",
                    "beginCaptures": {
                        "0": { "name": "punctuation.section.embedded.begin.veldora" }
                    },
                    "end": "!!\\}",
                    "endCaptures": {
                        "0": { "name": "punctuation.section.embedded.end.veldora" }
                    },
                    "patterns": [
                        { "include": "source.php" }
                    ]
                }
            ]
        },

        "veldora-echo": {
            "patterns": [
                {
                    "name": "meta.expression.veldora",
                    "begin": "\\{\\{",
                    "beginCaptures": {
                        "0": { "name": "punctuation.section.embedded.begin.veldora" }
                    },
                    "end": "\\}\\}",
                    "endCaptures": {
                        "0": { "name": "punctuation.section.embedded.end.veldora" }
                    },
                    "patterns": [
                        { "include": "source.php" }
                    ]
                }
            ]
        },

        "veldora-directives": {
            "patterns": [
                {
                    "comment": "Paired directives with parentheses arguments",
                    "name": "keyword.control.veldora",
                    "match": "@(if|elseif|unless|foreach|forelse|for|while|php|auth|guest|admin|dump|include|extends|section|yield|push|stack|component|slot|props)\\b"
                },
                {
                    "comment": "Closing / standalone directives",
                    "name": "keyword.control.veldora",
                    "match": "@(else|endif|endunless|endforeach|empty|endforelse|endfor|endwhile|endphp|csrf|endauth|endguest|endadmin|endsection|endpush|endslot|endcomponent)\\b"
                }
            ]
        },

        "veldora-components": {
            "patterns": [
                {
                    "name": "meta.tag.custom.veldora",
                    "begin": "</?x-[a-zA-Z0-9_\\-\\.]+",
                    "beginCaptures": {
                        "0": { "name": "entity.name.tag.veldora" }
                    },
                    "end": "/?>",
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.tag.end.veldora" }
                    },
                    "patterns": [
                        {
                            "name": "entity.other.attribute-name.veldora",
                            "match": "\\b[a-zA-Z0-9_\\-\\:]+(?==)"
                        },
                        {
                            "name": "string.quoted.double.veldora",
                            "begin": "\"",
                            "end": "\"",
                            "patterns": [
                                { "include": "#veldora-echo" }
                            ]
                        },
                        {
                            "name": "string.quoted.single.veldora",
                            "begin": "'",
                            "end": "'"
                        }
                    ]
                }
            ]
        }
    }
}
