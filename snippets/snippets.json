{
    "Veldora If Statement": {
        "prefix": "v-if",
        "body": [
            "@if (${1:\\$condition})",
            "\t$0",
            "@endif"
        ],
        "description": "Veldora @if directive"
    },
    "Veldora Foreach Statement": {
        "prefix": "v-foreach",
        "body": [
            "@foreach (${1:\\$items} as ${2:\\$item})",
            "\t$0",
            "@endforeach"
        ],
        "description": "Veldora @foreach directive"
    },
    "Veldora Yield Section": {
        "prefix": "v-yield",
        "body": [
            "@yield('${1:content}')"
        ],
        "description": "Veldora @yield directive"
    },
    "Veldora Extends": {
        "prefix": "v-extends",
        "body": [
            "@extends('${1:layouts.main}')"
        ],
        "description": "Veldora @extends directive"
    },
    "Veldora Section": {
        "prefix": "v-section",
        "body": [
            "@section('${1:content}')",
            "\t$0",
            "@endsection"
        ],
        "description": "Veldora @section directive"
    },
    "Veldora Escape": {
        "prefix": "v-esc",
        "body": [
            "{{ ${1:\\$var} }}"
        ],
        "description": "Veldora {{ }} variable output"
    },
    "Veldora Component": {
        "prefix": "v-comp",
        "body": [
            "<x-${1:component}>",
            "\t$0",
            "</x-$1>"
        ],
        "description": "Veldora custom component tag"
    },
    "Veldora CSRF Field": {
        "prefix": "v-csrf",
        "body": [
            "@csrf"
        ],
        "description": "Veldora @csrf field helper"
    },
    "Veldora Auth Block": {
        "prefix": "v-auth",
        "body": [
            "@auth",
            "\t$0",
            "@endauth"
        ],
        "description": "Veldora @auth middleware conditional block"
    },
    "Veldora Guest Block": {
        "prefix": "v-guest",
        "body": [
            "@guest",
            "\t$0",
            "@endguest"
        ],
        "description": "Veldora @guest middleware conditional block"
    },
    "Veldora Admin Block": {
        "prefix": "v-admin",
        "body": [
            "@admin",
            "\t$0",
            "@endadmin"
        ],
        "description": "Veldora @admin conditional block"
    },
    "Veldora Unless Statement": {
        "prefix": "v-unless",
        "body": [
            "@unless (${1:\\$condition})",
            "\t$0",
            "@endunless"
        ],
        "description": "Veldora @unless directive"
    },
    "Veldora Forelse Statement": {
        "prefix": "v-forelse",
        "body": [
            "@forelse (${1:\\$items} as ${2:\\$item})",
            "\t$0",
            "@empty",
            "\t",
            "@endforelse"
        ],
        "description": "Veldora @forelse loop with empty fallback"
    },
    "Veldora For Loop": {
        "prefix": "v-for",
        "body": [
            "@for (${1:\\$i = 0}; ${2:\\$i < \\$count}; ${3:\\$i++})",
            "\t$0",
            "@endfor"
        ],
        "description": "Veldora @for loop"
    },
    "Veldora While Loop": {
        "prefix": "v-while",
        "body": [
            "@while (${1:\\$condition})",
            "\t$0",
            "@endwhile"
        ],
        "description": "Veldora @while loop"
    },
    "Veldora PHP Block": {
        "prefix": "v-php",
        "body": [
            "@php",
            "\t$0",
            "@endphp"
        ],
        "description": "Veldora inline PHP tag block"
    },
    "Veldora Dump Expression": {
        "prefix": "v-dump",
        "body": [
            "@dump(${1:\\$var})"
        ],
        "description": "Veldora @dump expression debugger"
    },
    "Veldora UI Button": {
        "prefix": "vc-button",
        "body": [
            "<x-button variant=\"${1:primary}\" size=\"${2:md}\">${3:Click me}</x-button>"
        ],
        "description": "Veldora UI button component"
    },
    "Veldora UI Input": {
        "prefix": "vc-input",
        "body": [
            "<x-input name=\"${1:field}\" label=\"${2:Label}\" type=\"${3:text}\" error=\"${4:\\$errors['$1'] ?? null}\" />"
        ],
        "description": "Veldora UI input field"
    },
    "Veldora UI Textarea": {
        "prefix": "vc-textarea",
        "body": [
            "<x-textarea name=\"${1:field}\" label=\"${2:Label}\" error=\"${3:\\$errors['$1'] ?? null}\" />"
        ],
        "description": "Veldora UI textarea field"
    },
    "Veldora UI Select": {
        "prefix": "vc-select",
        "body": [
            "<x-select name=\"${1:field}\" label=\"${2:Label}\" :options=\"${3:\\$options}\" selected=\"${4:\\$selected}\" error=\"${5:\\$errors['$1'] ?? null}\" />"
        ],
        "description": "Veldora UI select dropdown"
    },
    "Veldora UI Checkbox": {
        "prefix": "vc-checkbox",
        "body": [
            "<x-checkbox name=\"${1:field}\" label=\"${2:Label}\" checked=\"${3:\\$checked}\" error=\"${4:\\$errors['$1'] ?? null}\" />"
        ],
        "description": "Veldora UI checkbox toggle"
    },
    "Veldora UI Radio": {
        "prefix": "vc-radio",
        "body": [
            "<x-radio name=\"${1:field}\" value=\"${2:value}\" label=\"${3:Label}\" checked=\"${4:\\$checked}\" />"
        ],
        "description": "Veldora UI radio select"
    },
    "Veldora UI Badge": {
        "prefix": "vc-badge",
        "body": [
            "<x-badge variant=\"${1:success}\">${2:Active}</x-badge>"
        ],
        "description": "Veldora UI status badge"
    },
    "Veldora UI Alert": {
        "prefix": "vc-alert",
        "body": [
            "<x-alert variant=\"${1:success}\" title=\"${2:Title}\">${3:Message}</x-alert>"
        ],
        "description": "Veldora UI alert notification box"
    },
    "Veldora UI Card": {
        "prefix": "vc-card",
        "body": [
            "<x-card title=\"${1:Card Title}\">",
            "\t${2:<p>Card content</p>}",
            "</x-card>"
        ],
        "description": "Veldora UI layout card"
    },
    "Veldora UI Modal": {
        "prefix": "vc-modal",
        "body": [
            "<x-modal id=\"${1:modal-id}\" title=\"${2:Modal Title}\">",
            "\t${3:<p>Modal content</p>}",
            "</x-modal>"
        ],
        "description": "Veldora UI dialog modal"
    },
    "Veldora UI Spinner": {
        "prefix": "vc-spinner",
        "body": [
            "<x-spinner size=\"${1:md}\" />"
        ],
        "description": "Veldora UI loading spinner"
    },
    "Veldora UI Avatar": {
        "prefix": "vc-avatar",
        "body": [
            "<x-avatar src=\"${1:\\$user->avatar}\" name=\"${2:\\$user->name}\" size=\"${3:md}\" />"
        ],
        "description": "Veldora UI avatar thumbnail"
    },
    "Veldora UI Dropdown": {
        "prefix": "vc-dropdown",
        "body": [
            "<x-dropdown label=\"${1:Dropdown}\">",
            "\t<li><a href=\"#\">${2:Option 1}</a></li>",
            "</x-dropdown>"
        ],
        "description": "Veldora UI dropdown select menu"
    },
    "Veldora UI Navbar": {
        "prefix": "vc-navbar",
        "body": [
            "<x-navbar brand=\"${1:Brand}\">",
            "\t<a href=\"#\">${2:Home}</a>",
            "</x-navbar>"
        ],
        "description": "Veldora UI main navigation bar"
    },
    "Veldora UI Toast": {
        "prefix": "vc-toast",
        "body": [
            "<x-toast id=\"${1:toast-id}\" variant=\"${2:success}\" message=\"${3:Action completed!}\" />"
        ],
        "description": "Veldora UI auto-dismiss toast notification"
    }
}
