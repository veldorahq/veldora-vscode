{
    "name": "veldora-vscode",
    "displayName": "Veldora Language Support",
    "description": "Syntax highlighting, file icons, snippets, and language configuration for Veldora (.veldora.php) template files.",
    "version": "0.5.0",
    "publisher": "veldora",
    "icon": "images/v-icon.png",
    "galleryBanner": {
        "color": "#7c3aed",
        "theme": "dark"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/veldorahq/veldora-vscode"
    },
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "keywords": [
        "veldora",
        "php",
        "template",
        "blade",
        "mvc",
        "syntax",
        "snippets",
        "framework"
    ],
    "contributes": {
        "languages": [
            {
                "id": "veldora",
                "aliases": [
                    "Veldora",
                    "veldora"
                ],
                "extensions": [
                    ".veldora"
                ],
                "filenamePatterns": [
                    "*.veldora.php",
                    "*.veldora"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "veldora",
                "scopeName": "text.html.veldora",
                "path": "./syntaxes/veldora.tmLanguage.json",
                "embeddedLanguages": {
                    "text.html.derivative": "html",
                    "source.php": "php",
                    "meta.embedded.block.php": "php",
                    "meta.embedded.line.php": "php"
                }
            }
        ],
        "snippets": [
            {
                "language": "veldora",
                "path": "./snippets/snippets.json"
            }
        ]
    }
}